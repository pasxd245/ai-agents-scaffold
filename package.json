{
  "name": "a2scaffold",
  "version": "0.0.2",
  "description": "CLI tool to scaffold AI agent configuration files in any repository",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "a2scaffold": "bin/a2scaffold"
  },
  "files": [
    "bin/",
    "src/",
    "templates/"
  ],
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . && markdownlint-cli2",
    "lint:js": "eslint .",
    "lint:md": "markdownlint-cli2",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.js",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.md": [
      "prettier --write",
      "markdownlint-cli2 --fix"
    ],
    "*.{json,jsonc,yaml,yml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "ai",
    "agent",
    "agents",
    "scaffold",
    "scaffolding",
    "generator",
    "boilerplate",
    "cli",
    "template",
    "llm"
  ],
  "author": "Vien Pham",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pasxd245/ai-agents-scaffold.git"
  },
  "homepage": "https://github.com/pasxd245/ai-agents-scaffold#readme",
  "bugs": {
    "url": "https://github.com/pasxd245/ai-agents-scaffold/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.22.0",
  "dependencies": {
    "@nci-gis/js-tmpl": "^0.1.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
